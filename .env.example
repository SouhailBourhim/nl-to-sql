# SQLAlchemy connection string.
# For the Spider test fixture (SQLite):
#   DATABASE_URL=sqlite:///spider_data/database/dog_kennels/dog_kennels.sqlite
# For your real Postgres DB:
#   DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///spider_data/database/dog_kennels/dog_kennels.sqlite

# Which LLM backend to use: "ollama" (default, local/free) or "api" (hosted, OpenAI-compatible)
LLM_BACKEND=ollama

# Ollama settings (used when LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=sqlcoder
OLLAMA_TEMPERATURE=0.3
OLLAMA_TIMEOUT_SECONDS=240

# Hosted API settings (used when LLM_BACKEND=api) -- default points at NVIDIA's
# OpenAI-compatible endpoint (https://build.nvidia.com); get a free API key there.
# API_BASE_URL=https://integrate.api.nvidia.com/v1
# API_KEY=
# API_MODEL=meta/llama-3.1-70b-instruct
# API_TEMPERATURE=0.2
# API_MAX_TOKENS=1024
# API_TIMEOUT_SECONDS=120

# Safety cap: max rows returned by any query if the LLM doesn't add its own LIMIT
MAX_RESULT_ROWS=200

# Safety cap: kill a query server-side (Postgres only) if it runs longer than this
STATEMENT_TIMEOUT_MS=5000
