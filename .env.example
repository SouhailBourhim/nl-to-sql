# SQLAlchemy connection string.
# For the Spider test fixture (SQLite):
#   DATABASE_URL=sqlite:///spider_data/database/dog_kennels/dog_kennels.sqlite
# For your real Postgres DB:
#   DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///spider_data/database/dog_kennels/dog_kennels.sqlite

# Which LLM backend to use: "ollama" (default, local/free) or "api" (hosted)
LLM_BACKEND=ollama

# Ollama settings (used when LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=sqlcoder

# Hosted API settings (used when LLM_BACKEND=api) — not needed for the default path
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Safety cap: max rows returned by any query if the LLM doesn't add its own LIMIT
MAX_RESULT_ROWS=200
